<Window x:Class="OpenCvStudy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenCvStudy"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        WindowStyle="None"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- 상단 패널 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock Text="이물 감지기" FontSize="30" FontWeight="Bold" Margin="10, 10, 10, 10"/>
                </StackPanel>
            </Grid>

            <!-- Load/Clear 버튼 패널 -->
            <Grid Grid.Column="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding UploadImageCommand}" Cursor="Hand" Content="Image Load" Height="30" Width="100" Margin="10, 10, 10, 10"/>
                    <Button Command="{Binding ClearImageCommand}" 
                            Click="CleanButton_Click"
                            Cursor="Hand" Content="Clean" Height="30" Width="100" Margin="10, 10, 10, 10"/>
                </StackPanel>
            </Grid>
            <!-- Load/Clear 버튼 패널 -->
            
            <!-- Button Panel -->
            
            <!--확대/축소 버튼 패널-->
            <Grid Grid.Column="2" HorizontalAlignment="Right">
                    <Button Command="{Binding ExitCommand}" Cursor="Hand" Content="Exit" Height="30" Width="30" Margin="10, 10, 10, 10"/>
            </Grid>
            <!--확대/축소 버튼 패널-->

            <Rectangle Grid.ColumnSpan="3" 
                       Height="4" 
                       Fill="#FF929292" 
                       VerticalAlignment="Bottom" 
                       Margin="10, 0, 10, 0"
                       SnapsToDevicePixels="True"/>

        </Grid>
        <!-- 상단 패널 -->
        
        <!-- 중단 패널 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 중단 왼쪽 패널 -->
            <Grid Grid.Column="0" Margin="30, 30, 30, 30" 
                  ClipToBounds="True"
                  Background="Transparent"
                  MouseWheel="Image_MouseWheel"
                  MouseLeftButtonDown="Image_MouseLeftButtonDown"
                  MouseLeftButtonUp="Image_MouseLeftButtonUp"
                  MouseMove="Image_MouseMove">

                <!--RenderTransformOrigin ="0.5,0.5" -> 중앙 기준으로 확대/축소-->
                <Image x:Name="DisplayImage" 
                       Source="{Binding DisplayImage}" 
                       Stretch="Uniform" 
                       RenderTransformOrigin="0,0" 
                       PreviewMouseRightButtonDown="MainImage_PreviewMouseRightButtonDown"
                       PreviewMouseRightButtonUp="MainImage_PreviewMouseRightButtonUp"
                       Cursor="Hand">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <!--마우스 휠 동작-->
                            <ScaleTransform x:Name="imageScale" ScaleX="1.0" ScaleY="1.0"/>
                            <!--상하좌우 이동-->
                            <TranslateTransform x:Name="imageTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <Rectangle Stroke="#FF929292" 
                           StrokeThickness="2"
                           StrokeDashArray="4 4"
                           SnapsToDevicePixels="True"
                           IsHitTestVisible="False"/>
            </Grid>
            <!-- 중단 왼쪽 패널 -->

            <!-- 중단 오른쪽 패널 -->
            <Grid Grid.Column="1" Margin="15, 30, 30, 30">

                <TextBlock Text="검사 모드 (Inspection Mode)" Foreground="#E0E0E0" FontSize="20" FontWeight="Bold" Margin="0, 0, 0, 10"/>
                <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 20">
                    <RadioButton Content="이물 검사"
                         FontSize="15"
                         Foreground="#E0E0E0" 
                         IsChecked="{Binding Settings.IsRuleBasedMode}"
                         GroupName="ModeGroup" 
                         Cursor="Hand" Margin="0, 50, 15, 0"/>

                    <RadioButton Content="알약 불량" 
                         FontSize="15"
                         Foreground="#E0E0E0" 
                         IsChecked="{Binding Settings.IsDeepLearningMode}"
                         GroupName="ModeGroup" 
                         Cursor="Hand" Margin="0, 50, 15, 0"/>
                </StackPanel>

                <Rectangle Height="2" Fill="#FF444444" Margin="0, 0, 0, 20" SnapsToDevicePixels="True"/>

                <Border Background="#2D2D30" CornerRadius="5" Padding="15" Margin="0, 100, 0, 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Defect List" 
                                   Foreground="#E0E0E0" 
                                   FontSize="40" 
                                   FontWeight="Bold" 
                                   Margin="5, 0, 0, 15"
                                   HorizontalAlignment="Center"/>

                        <ListBox Grid.Row="1" 
                                 ItemsSource="{Binding DefectList}"
                                 SelectedItem="{Binding SelectedDefect}"
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E1E" CornerRadius="5" Margin="5, 5, 5, 10" Padding="10">
                                        <StackPanel Orientation="Vertical">

                                            <Image Source="{Binding DefectImage}" Height="120" Stretch="Uniform" Margin="0, 0, 0, 10"/>

                                            <TextBlock Text="{Binding DefectInfo}" 
                                                       Foreground="#FF929292" 
                                                       HorizontalAlignment="Center" 
                                                       FontSize="14"/>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
            <!-- 중단 오른쪽 패널 -->
        </Grid>
        <!-- 중단 패널 -->
        
        <!--하단 패널-->
        <!-- 파라미터 설정 패널 영역 -->
        <Grid Grid.Row="2">
            <!-- 1. 룰 기반 모드 전용 패널 -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <!-- 기본적으로 숨김 -->
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- IsDeepLearningMode가 False일 때만 표시 -->
                            <DataTrigger Binding="{Binding Settings.IsDeepLearningMode}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding Settings.MinDefectPixels, StringFormat='이물 픽셀 크기 (Min Defect Pixels) : {0}'}" FontSize="30"/>
                <Slider Minimum="0" Maximum="100" Value="{Binding Settings.MinDefectPixels}" />

                <TextBlock Text="{Binding Settings.ThresholdSensitivity, StringFormat='이물 민감도 (Threshold Sensitivity) : {0}'}" FontSize="30"/>
                <Slider Minimum="0" Maximum="255" Value="{Binding Settings.ThresholdSensitivity}" />

                <TextBlock Text="{Binding Settings.MinShapeArea, StringFormat='이물 최소 면적 (Min Shape Area) : {0}'}" FontSize="30"/>
                <Slider Minimum="0" Maximum="10000" Value="{Binding Settings.MinShapeArea}" />
            </StackPanel>

            <!-- 2. 딥러닝 모드 전용 패널 -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- IsDeepLearningMode가 True일 때만 표시 -->
                            <DataTrigger Binding="{Binding Settings.IsDeepLearningMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding Settings.AnomalyThreshold, StringFormat='불량 판정 기준점 (Anomaly Threshold) : {0:N1}'}" FontSize="30"  />
                <!-- 0.1부터 5.0 사이 등 모델 결과에 맞게 범위 조절 -->
                <Slider Minimum="0.1" Maximum="5.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding Settings.AnomalyThreshold}" />

                <TextBlock Text="{Binding Settings.MaxExpectedScore, StringFormat='시각화 최대 점수 (Max Expected Score) : {0:N1}'}" FontSize="30" Margin="0,10,0,0" />
                <Slider Minimum="0.5" Maximum="10.0" TickFrequency="0.5" IsSnapToTickEnabled="True" Value="{Binding Settings.MaxExpectedScore}" />
            </StackPanel>
        </Grid>
        <!--하단 패널-->
    </Grid>
    
</Window>
