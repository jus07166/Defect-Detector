################################################################################
# 이 .gitignore 파일은 Microsoft(R) Visual Studio에서 자동으로 만들어졌습니다.
################################################################################

# 패키지 및 대용량 파일
packages/
*.nupkg
Test_Image/
Sample_Data/
*.zip
*.db

# 2. Visual Studio 로컬 설정 (개인 PC 설정이므로 공유 불필요)
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# 3. C# / .NET 빌드 결과물 (빌드하면 다시 생성되므로 용량만 차지함)
[Bb]in/
[Oo]bj/
*.exe
*.dll
*.pdb

# C++ / C# 빌드 결과물 폴더 무시
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# Visual Studio 임시 및 로그 파일 직접 무시
*.tlog
*.log
*.idb
*.pdb
*.ilk
.vs/
